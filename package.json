{
  "name": "bpdiscord",
  "version": "1.0.0",
  "description": "BPDiscord - A full-stack web application with TypeScript Express API and React frontend",
  "private": true,
  "scripts": {
    "build": "cd src/server && tsc",
    "build:server": "cd src/server && tsc",
    "build:client": "cd src/client && yarn build",
    "start": "node src/server/dist/server/server.js",
    "dev": "concurrently --kill-others --raw \"yarn dev:server\" \"yarn dev:client\"",
    "dev:server": "cd src/server && yarn dev",
    "dev:client": "cd src/client && yarn dev",
    "dev:local": "concurrently --kill-others --raw \"yarn dev:server:local\" \"yarn dev:client:local\"",
    "dev:server:local": "cd src/server && SMOKE_LOCAL=1 yarn dev",
    "dev:client:local": "cd src/client && yarn dev --mode smoke",
    "setup:local": "cd src/server && yarn ts-node-dev --transpile-only --exit-child --no-notify scripts/setupLocalSmoke.ts",
    "seed:graph": "cd src/server && yarn seed:graph",
    "seed:retry": "cd src/server && yarn seed:retry",
    "backfill:film-years": "cd src/server && yarn backfill:film-years",
    "install:all": "yarn install && cd src/server && yarn install && cd ../client && yarn install",
    "clean": "rimraf src/server/dist && cd src/client && rimraf build",
    "kill-dev": "pkill -9 -f 'ts-node-dev' || true && pkill -9 -f 'vite' || true && echo 'Dev servers killed'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "axios": "^1.11.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "radix-ui": "^1.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "concurrently": "^9.1.0",
    "rimraf": "^5.0.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "typescript",
    "express",
    "react",
    "supabase",
    "letterboxd"
  ],
  "author": "Your Name",
  "license": "MIT"
}
