# Vite loads .env.smoke ONLY when started with `--mode smoke` (i.e. via
# `yarn dev:client:local`). `yarn dev` runs in default `--mode development`
# which loads only `.env`, leaving normal dev pointed at prod.
#
# This file is gitignored. Run `yarn setup:local` from the project root
# to populate it (alongside src/server/.env.smoke).

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=__from_supabase_status__
