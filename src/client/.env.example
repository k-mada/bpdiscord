# Vite client env. Copy to .env for prod / dev-against-prod, or to
# .env.local for local-smoke mode (Vite loads .env.local automatically
# when present; .env.local is gitignored).

# API base URL. Leave commented to use Vite's dev proxy (forwards /api
# to localhost:3001). Set explicitly for production builds.
# VITE_API_URL=/api

VITE_HOT_RELOAD=true

# Supabase client — required by client-direct flows (password reset).
# The anon key is public by design; safe to commit if you want a single
# env shared across the team.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
