# Smoke-mode overrides. Loaded ONLY when SMOKE_LOCAL=1 is set (i.e. via
# `yarn dev:local`). Values here override `.env`; dotenv's no-override
# semantics mean the first file to define a variable wins.
#
# `yarn dev` does NOT load this file — normal dev points at prod.
#
# Don't edit by hand. Run `yarn setup:local` to auto-populate from
# `supabase status -o env` and seed the local admin user + fixtures.
#
# This file IS gitignored. Safe to contain local secrets (which are
# Supabase's well-known demo keys anyway).

# Local Supabase (from `supabase status -o env` — supabase start required)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=__from_supabase_status__
SUPABASE_SERVICE_ROLE_KEY=__from_supabase_status__
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# JWT secret matching the local Supabase instance.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Worker NOT configured locally — /api/scrape-user and /api/admin/refresh-rankings
# will return 500 "Worker not configured". Per design (bpdiscord-8z2): test
# worker scenarios on prod, not in local smoke.
WORKER_URL=
WORKER_SHARED_SECRET=

# CLIENT_URL is used by the password-reset redirect. Vite dev runs on 5173.
CLIENT_URL=http://localhost:5173
