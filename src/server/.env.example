# Copy this file to .env and fill in real values. For local-smoke testing
# (recommended for PRs), copy .env.local.example to .env.local instead —
# loadEnv.ts loads .env.local first when present, falling back to .env.

# ===========================
# Supabase (prod / cloud project)
# ===========================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Drizzle / postgres-js — the Supabase pooler URL (port 6543, NOT 5432).
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ===========================
# Test database (vitest)
# ===========================
# Points at local Supabase by default. Run `supabase start` to bring it up.
DATABASE_URL_TEST=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ===========================
# Server
# ===========================
PORT=3001
NODE_ENV=development
JWT_SECRET=your-jwt-secret

# ===========================
# Moviemaestro worker (Railway)
# Required by /api/scrape-user/* and /api/admin/refresh-rankings.
# Leave empty in local-smoke mode → endpoints return 500 "Worker not configured".
# ===========================
WORKER_URL=https://moviemaestro-production.up.railway.app
WORKER_SHARED_SECRET=shared-with-moviemaestro

# ===========================
# TMDB (for /api/actor-graph ingestion)
# Read API token (v4), not the v3 API key.
# ===========================
TMDB_READ_API_TOKEN=your-tmdb-v4-read-token

# ===========================
# Optional: prod client URL for password reset redirects
# ===========================
# CLIENT_URL=https://bpdiscord.vercel.app
